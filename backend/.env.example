# Copy this file to `.env` (in the repo root, next to docker-compose.yml)
# and adjust values as needed. `.env` is git-ignored -- never commit real
# secrets.

# ---- General ----
APP_NAME=care-ai-backend
ENV=local
DEBUG=true

# ---- Logging ----
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# JSON_LOGS=false gives human-readable console logs (local dev).
# Set to true in staging/production for machine-parseable JSON logs.
JSON_LOGS=false

# ---- API server ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- Database ----
# These POSTGRES_* values are consumed by the `db` service in
# docker-compose.yml to initialize the Postgres container.
POSTGRES_USER=careai
POSTGRES_PASSWORD=careai_dev_password
POSTGRES_DB=careai
POSTGRES_PORT=5432

# DATABASE_URL is consumed by the backend app + Alembic. The host
# "db" is the docker-compose service name -- if running the backend
# outside Docker, change it to "localhost".
DATABASE_URL=postgresql+asyncpg://careai:careai_dev_password@db:5432/careai
DB_ECHO=false

# ---- Retell ----
# Webhook signature verification uses the API key that has the webhook
# badge in the Retell dashboard. Leave blank / set VERIFY to false for
# local curl testing without signatures.
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_LLM_ID=
RETELL_VERIFY_SIGNATURES=false
