# Root-level env file, consumed by `docker-compose.yml` (both for the
# ${VAR} substitutions in that file and, via `env_file:`, as the backend
# container's environment). Copy to `.env` before running
# `docker compose up`. See backend/.env.example for the same variables
# with more detailed comments -- kept in sync with this file.

APP_NAME=care-ai-backend
ENV=local
DEBUG=true

LOG_LEVEL=INFO
JSON_LOGS=false

API_HOST=0.0.0.0
API_PORT=8000

POSTGRES_USER=careai
POSTGRES_PASSWORD=careai_dev_password
POSTGRES_DB=careai
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://careai:careai_dev_password@db:5432/careai
DB_ECHO=false

# ---- PMS ----
# The mock provider persists an idempotent write-back record after a booking.
# Keep this default for a clone; do not point a local review at a real PMS.
PMS_PROVIDER=mock
PMS_RETRY_MAX_ATTEMPTS=5
PMS_RETRY_BASE_SECONDS=30

# ---- Retell ----
# Leave blank locally to skip webhook signature verification.
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_LLM_ID=
RETELL_VERIFY_SIGNATURES=false

# ---- Bolna ----
# Bearer token Bolna sends as Authorization when calling custom tools.
# Use the same value in each tool's api_token field (with or without "Bearer ").
BOLNA_API_TOKEN=
BOLNA_AGENT_ID=
BOLNA_VERIFY_AUTH=false

# ---- Demo mock PMS console ----
CORS_ORIGINS=
